rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Quy tắc cho Phòng Chat cộng đồng (Ai cũng đọc được, đăng nhập mới được chat)
    match /chats/{chatId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (resource.data.userId == request.auth.uid || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }
    
    // 2. Quy tắc cho Người dùng (Chỉ cho phép sửa đổi thông tin cá nhân, không tự tăng tiền hay phân quyền Admin)
    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == userId
                    && request.resource.data.balance == 0
                    && request.resource.data.role == 'user';
      allow update: if request.auth != null && (
        (request.auth.uid == userId 
         && request.resource.data.role == resource.data.role
         && request.resource.data.balance <= resource.data.balance)
        || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
      allow delete: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // 3. Quy tắc cho Blog & Bình luận Blog
    match /blogs/{blogId} {
      allow read: if true;
      allow create, delete: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow update: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
        || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views'])
            && request.resource.data.views == resource.data.views + 1)
      );
    }
    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (resource.data.userId == request.auth.uid || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    // 4. Quy tắc cho Game trong store
    match /games/{gameId} {
      allow read: if true;
      allow create, delete: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow update: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
        || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views'])
            && request.resource.data.views == resource.data.views + 1)
      );
    }

    // 4b. Quy tắc cho Sticker (Ai cũng xem được, đăng nhập mới được thêm)
    match /stickers/{stickerId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // 5. Quy tắc cho Video & Bình luận Video
    match /videos/{videoId} {
      allow read: if true;
      allow create, delete: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow update: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
        || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views'])
            && request.resource.data.views == resource.data.views + 1)
      );
    }
    match /video_comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (resource.data.userId == request.auth.uid || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    // 6. Quy tắc cho bảng Báo lỗi & Hỗ trợ
    match /reports/{document} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      allow update, delete: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // 6b. Quy tắc cho bảng Báo lỗi Game/Phim (error_reports)
    match /error_reports/{document} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
                            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // 7. Quy tắc cho bảng Ví nạp tiền (Tránh user tự đổi trạng thái nạp thành thành công)
    match /payments/{document} {
      allow read: if request.auth != null;
      allow create: if request.auth != null 
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.status == 'pending';
      allow update: if request.auth != null 
                    && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
                        || (request.resource.data.userId == request.auth.uid 
                            && request.resource.data.status == resource.data.status));
      allow delete: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
