rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Quy tắc cho Phòng Chat cộng đồng (Ai cũng đọc được, đăng nhập mới được chat)
    match /chats/{chatId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // 2. Quy tắc cho Người dùng (User chính mình hoặc Admin mới được sửa tiền & thông tin)
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && (request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    // 3. Quy tắc cho Blog & Bình luận Blog
    match /blogs/{blogId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /comments/{commentId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 4. Quy tắc cho Game trong store
    match /games/{gameId} {
      allow read: if true;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // 4b. Quy tắc cho Sticker (Ai cũng xem được, đăng nhập mới được thêm)
    match /stickers/{stickerId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 5. Quy tắc cho Video & Bình luận Video
    match /videos/{videoId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /video_comments/{commentId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 6. Quy tắc cho bảng Báo lỗi & Hỗ trợ
    match /reports/{document} {
      allow read, write: if request.auth != null;
    }
    
    // 7. Quy tắc cho bảng Ví nạp tiền
    match /payments/{document} {
      allow read, write: if request.auth != null;
    }
  }
}
